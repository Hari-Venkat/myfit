APP_URL="http://localhost:3000"

# Google Fit API (Optional - for auto-syncing health data)
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Enable "Fitness API" at: https://console.cloud.google.com/apis/library/fitness.googleapis.com
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
